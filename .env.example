# --- Supabase 우선 연동(권장 경로) ---
# 대시보드: Project Settings → API → Project URL / anon public key / JWT Secret
# VITE_USE_SUPABASE_AUTH=true
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=
# 백엔드: Supabase가 서명한 access_token(JWT) 검증
# AUTH_PROVIDER=supabase
# SUPABASE_JWT_SECRET=
# 쉼표로 구분한 관리자 이메일(선택). user_metadata.role 이 없을 때 admin 판별에 사용
# SUPABASE_ADMIN_EMAILS=admin@company.com

# --- 시놀로지 NAS 등 자체 PostgreSQL + 앱 JWT (Supabase 미사용 시) ---
# AUTH_PROVIDER=jwt
# JWT for /api/auth (production: min 16 chars, random). Dev may omit (insecure fallback).
# JWT_SECRET=
# JWT_EXPIRES_IN=7d

# 데이터베이스: Supabase의 Postgres 연결 문자열을 쓰거나, 나중에 NAS의 PG URL로 바꿀 수 있습니다(동일 pool).
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# 또는:
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=
# PGDATABASE=reliability

# Optional: override API origin. If empty, the frontend uses http://localhost:3000.
# Set this for NAS/production (e.g. https://nas.example.com).
VITE_API_BASE_URL=

# Google AI Studio → API 키 (요약 등)
VITE_GEMINI_API_KEY=

# 프론트만 작업 시 true — 서버 없이 로그인·보호 라우트 통과 (배포·실서버 연동 전에는 false 또는 삭제)
# VITE_AUTH_OFFLINE=true

# Backend (Node) — default 3000 (matches Vite /api proxy in vite.config.ts)
# PORT=3000
# DATA_DIR=C:\path\to\COWAY-TEST\data
# Optional: comma-separated allowed origins. If unset, CORS reflects request origin (dev-friendly).
# CORS_ORIGIN=https://app.example.com,https://admin.example.com

# PostgreSQL — ETL: npm run import:data (scripts/importCsv.js) or npm run import-pg
