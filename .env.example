# Optional: override API origin. If empty, the frontend uses http://localhost:3000.
# Set this for NAS/production (e.g. https://nas.example.com).
VITE_API_BASE_URL=

# Google AI Studio → API 키 (요약 등)
VITE_GEMINI_API_KEY=

# Backend (Node) — default 3000 (matches Vite /api proxy in vite.config.ts)
# PORT=3000
# DATA_DIR=C:\path\to\RV-SYSTEM\data
# Optional: comma-separated allowed origins. If unset, CORS reflects request origin (dev-friendly).
# CORS_ORIGIN=https://app.example.com,https://admin.example.com

# PostgreSQL — ETL: npm run import:data (scripts/importCsv.js) or npm run import-pg
# Prefer one of:
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/reliability
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=
# PGDATABASE=reliability
