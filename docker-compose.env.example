# docker-compose.yml과 같은 디렉터리에 `.env`로 복사:
#   cp docker-compose.env.example .env

# --- PostgreSQL (필수: 강력한 비밀번호) ---
POSTGRES_USER=rvsystem
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=reliability

# --- 호스트에 노출할 웹 포트 (기본 8080) ---
FRONTEND_PORT=8080

# --- JWT (필수, 프로덕션: 16자 이상 무작위 문자열) ---
JWT_SECRET=replace-with-long-random-secret-at-least-16-chars
# JWT_EXPIRES_IN=7d

# --- 백엔드 CORS (선택) ---
# 비우면 동일 출처·개발 편의용 동작. 특정 도메인만 허용할 때 쉼표로 나열:
# CORS_ORIGIN=https://nas.example.com,http://192.168.1.10:8080

# --- 프론트 빌드 시 API 베이스 (선택) ---
# Nginx가 /api를 백엔드로 넘기는 구성이면 비워 두는 것이 일반적(브라우저는 같은 호스트의 /api 사용).
# 프론트만 다른 서버에 올릴 때만 예: VITE_API_BASE_URL=https://api.example.com
# VITE_API_BASE_URL=
