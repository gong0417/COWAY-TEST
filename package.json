{
  "name": "reliability-system",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "sync-db": "node scripts/sync-db.mjs",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run sync-db && npm run build -w frontend",
    "preview": "npm run preview -w frontend",
    "lint": "npm run lint -w frontend",
    "git-remote": "powershell -ExecutionPolicy Bypass -File ./scripts/git-setup-remote.ps1",
    "repair:caniuse": "node scripts/repair-caniuse.mjs",
    "import-pg": "node scripts/import-csv-to-pg.mjs",
    "import:data": "node scripts/importCsv.js",
    "test:db": "node scripts/test-db.mjs"
  },
  "dependencies": {
    "core-js": "^3.38.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "csv-parser": "^3.2.0",
    "papaparse": "^5.5.2",
    "pg": "^8.14.1"
  },
  "overrides": {
    "core-js": "^3.38.0",
    "caniuse-lite": "1.0.30001782",
    "browserslist": "4.28.2"
  }
}
